package "DEPENDENCY DIRECTION" as Dependencies #E3F2FD {
  component "Domain declarations\nannotations + nominal/value types only" as Domain #BBDEFB
  component "Generated domain implementation\nmetadata + records + sets" as GeneratedDomain #C8E6C9
  component "Generated EntityGraph\nruntime composition" as GeneratedGraph #C8E6C9
  component "Application composition + UI\ninjection · MobX Observer · Hooks" as AppUI #E1BEE7

  AppUI --> GeneratedGraph : uses
  GeneratedGraph --> GeneratedDomain : composes
  GeneratedDomain --> Domain : implements
}

package "ONE REUSABLE NODUS PACKAGE\none version · one setup · never depends on an application" as Reusable #FFF3E0 {
  component "public domain surface\nannotations · capabilities · nominal values" as Annotations #FFE0B2
  component "private compiler\nparser → canonical IR → inference → validation\nprovenance → deterministic emitters" as Generator #FFE0B2
  component "private narrow runtimes\nidentity · mutation · query · transaction\nlocal store · process · sync" as CoreRuntime #FFE0B2
  component "internal capability integrations\nDrift · MobX · Flutter · routing\ntarget/process/projection adapters" as Integrations #FFE0B2

  Generator --> Annotations
  CoreRuntime --> Annotations
  Integrations --> CoreRuntime
}

Domain --> Annotations
GeneratedDomain --> CoreRuntime
GeneratedGraph --> Integrations

package "ALLOWED NARROW EXTENSIONS" as Extensions #E8F5E9 {
  component "typed value/source codec or pure mapper" as Codec #C8E6C9
  component "typed SyncAdapter" as SyncAdapter #C8E6C9
  component "explicit conflict/authorization policy" as Policy #C8E6C9
  component "reviewed migration/backfill" as Migration #C8E6C9
  component "typed process/projection destination\nexternal device/payment/file/computation port" as Port #C8E6C9
}

Extensions ..> Generator : typed inputs, compile-time checked
Extensions ..> Integrations : injected at explicit composition boundary

package "FORBIDDEN SECOND MODELS / HIDDEN COSTS" as Forbidden #FFEBEE {
  component "Repositories · data/access · import/workflow services\ncommands/queries that only forward generated behavior" as NoRepo #FFCDD2
  component "Any duplicate entity/query state\nprovider/view-model mirrors · global invalidation" as NoProvider #FFCDD2
  component "Duplicate DTO/schema/serialization\nmanual registry/routes · raw IDs/maps" as NoDuplication #FFCDD2
  component "Runtime reflection · emitter re-inference · N+1\nunbounded scan · compiler-wide invalidation\nper-row I/O subscriptions · scope-free rank indexes" as NoHiddenCost #FFCDD2
}

package "EVERY CHANGE MUST PROVE" as Proof #F3E5F5 {
  component "Clean/no-op/incremental deterministic generation\n+ explain provenance + compile-failure contracts" as GenerateTest #E1BEE7
  component "Formatting + zero-warning static analysis" as StaticTest #E1BEE7
  component "Runtime + DB + sync-adapter + security tests" as RuntimeTest #E1BEE7
  component "UI precision + lifecycle cleanup tests" as UITest #E1BEE7
  component "Compiler + runtime bounded-cost budgets" as Bench #E1BEE7
  component "Generated-output + migration-inventory drift checks" as DriftCheck #E1BEE7

  GenerateTest --> StaticTest
  StaticTest --> RuntimeTest
  RuntimeTest --> UITest
  UITest --> Bench
  Bench --> DriftCheck
}

GeneratedGraph --> Proof : architectural change is accepted only after all gates

note bottom of Dependencies
  EntityGraphDefinition = immutable generated metadata.
  EntityGraphHost = optional platform identity/session composition.
  AccountEntityGraphSession = serialized account lifecycle.
  EntityGraph = one live account runtime.
  IdentityMap = stable observable entity instances.
  Drift = durable local source observed by the application.
  These names and responsibilities are never interchangeable.
end note

note bottom of Reusable
  One distribution package does not mean one implementation unit.
  Applications use the stable umbrella API and generated library;
  they never import src/ or assemble private runtimes.
end note

note bottom of Forbidden
  Renaming a wrapper to provider, repository, access, query, command, manager,
  controller, or service does not make mechanical forwarding architectural.
end note

note bottom of Proof
  Migration is complete only when no temporary wrapper/debt remains.
  Missing generic capability is built once inside Nodus, then consumers migrate mechanically.
end note
@enduml
