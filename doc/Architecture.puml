package "HANDWRITTEN INTENT\nsmall, stable, application-owned" as Authored #E3F2FD {
  abstract class "@Entity\nabstract public domain type" as Entity #BBDEFB
  component "Persisted fields + defaults\nnominal IDs + relationships\ninvariants + computed business methods" as EntityIntent #E3F2FD
  component "Typed ownership + concise capabilities\nOwnedBy<Self, Owner> · Ordered · Component\nArchivable · SoftDeletable · Activatable\nCollaborative<Principal> · ActivityTracked/ActivityOf" as Capabilities #E3F2FD
  artifact "nodus.lock\npackage graph identity" as GraphDeclaration #BBDEFB
  component "Filesystem pages\nwidget constructor = route contract" as Pages #E3F2FD
  component "Only irreducible overrides\nambiguity · policy · codec · target\nsource process · projection" as Overrides #E3F2FD

  Entity --> EntityIntent
  Entity --> Capabilities
  Overrides ..> Entity : only when inference is unsafe
}

package "BUILD-TIME ENTITY-FIRST GENERATION\nno runtime reflection" as Build #FFF3E0 {
  component "1. Parse the complete graph" as Parse #FFE0B2
  component "2. Normalize one typed\nsemantic intermediate representation" as Normalize #FFE0B2
  component "3. Infer once by precedence\ntype → default → name → relationship/index\n→ graph convention → explicit override" as Infer #FFE0B2
  component "4. Validate at compile time\nambiguity · collisions · unsafe relations\nunsupported types · adapter capabilities" as Validate #FFE0B2
  artifact "EntityGraphDefinition\nentities + resolved relationship proofs\n+ derivation provenance" as Definition #FFCC80
  component "5. Independent deterministic emitters\nconsume facts; never repeat inference" as Emit #FFE0B2
  component "Explain report\nvalue + reason + override + generated shape" as Explain #FFE0B2
  component "Isolated route pass\npage tree + nominal type/codec catalog" as RoutePass #FFE0B2

  Parse --> Normalize
  Normalize --> Infer
  Infer --> Validate
  Validate --> Definition
  Definition --> Emit
  Definition --> Explain
  Definition --> RoutePass
}

package "GENERATED PUBLIC CONTRACT\nnever hand-edit generated files" as Generated #E8F5E9 {
  component "Domain implementation\n<Entity>Record · observable fields\nvalidation · codecs · rollback" as Record #C8E6C9
  component "Mutation and process surface\n<Entity>Set.create/createFirst/fromSource\ndirect entity actions + collaboration\nautomatic atomic activity append\nbeginEdit + typed draft · transactions" as MutationApi #C8E6C9
  component "Read surface\nnominal IDs · typed queries\n<Entity>List named constructors\nrelationship cardinality + leases" as ReadApi #C8E6C9
  component "Local persistence\nDrift tables · mappings · indexes\nconstraints · reviewed migrations" as LocalArtifacts #C8E6C9
  component "Synchronization contract\nqueue codecs · target groups · registry\npush/pull protocol · upcasters" as SyncArtifacts #C8E6C9
  component "Target artifacts\nDDL · indexes · RLS/grants\nchange capture · RPC/provisioning" as RemoteArtifacts #C8E6C9
  component "Typed routing\npaths · parameters · guards\nexternal-input decoding" as RoutingArtifacts #C8E6C9
}

package "ONE LIVE ACCOUNT-SCOPED RUNTIME" as Runtime #F3E5F5 {
  component "Optional <Application>EntityGraphHost\nplatform identity subscription only" as EntityGraphHost #E1BEE7
  component "AccountEntityGraphSession\nserialized open · switch · close" as EntityGraphSession #E1BEE7
  component "<Application>EntityGraph\npublic domain facade" as EntityGraph #E1BEE7
  component "Generated <Entity>Sets\nqueries · transactions · relationships" as Sets #E1BEE7
  component "Private narrow runtimes\nidentity · mutation + activity · query · transaction\nlocal store · process · synchronization" as PrivateRuntimes #E1BEE7
  component "IdentityMap\none stable MobX entity object per ID" as IdentityMap #E1BEE7
  database "One account Drift store\naccepted + optimistic state\npending operations · conflicts\nqueue work · receipts · cursors" as Drift #D1C4E9
  component "One durable work scheduler\nsync · process · projection lanes" as Scheduler #E1BEE7
  component "Generated typed adapter registry" as Registry #E1BEE7

  EntityGraphHost --> EntityGraphSession
  EntityGraphSession --> EntityGraph
  EntityGraph *-- Sets
  EntityGraph *-- PrivateRuntimes
  PrivateRuntimes *-- IdentityMap
  PrivateRuntimes *-- Drift
  PrivateRuntimes *-- Scheduler
  PrivateRuntimes *-- Registry
}

Authored --> Parse : the only authored sources
Emit --> Record
Emit --> MutationApi
Emit --> ReadApi
Emit --> LocalArtifacts
Emit --> SyncArtifacts
Emit --> RemoteArtifacts
Pages --> RoutePass
RoutePass --> RoutingArtifacts

Record --> IdentityMap : concrete stable identities
MutationApi --> Sets
ReadApi --> Sets
LocalArtifacts --> Drift
SyncArtifacts --> Scheduler
SyncArtifacts --> Registry
Definition --> EntityGraph : opens only after definition\nand bindings validate

note bottom of EntityGraph
  entityGraph identifies the account, store, identity map,
  transaction coordinator, clock, ID source, and target registry.
  It exposes domain sets, not its private runtimes.
  It is not a model, repository, provider, or service locator.
end note

note bottom of EntityGraphHost
  A host is optional and lifecycle-only. It never proxies entity sets,
  persistence, mutations, queries, or synchronization.
end note

note bottom of Generated
  A declaration change regenerates mechanics end to end.
  It cannot invent product layout or real business decisions.
end note

legend bottom
  |= Surface |= Meaning |
  | Blue | Handwritten domain intent |
  | Orange | Build-time inference and validation |
  | Green | Deterministic generated contract |
  | Purple | Account-scoped runtime |
endlegend
@enduml


@startuml architecture-02-write-push-pull-observe
title 2/4 — One local-first write, asynchronous convergence, precise UI reaction

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam sequenceArrowThickness 1
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 90
skinparam noteBorderColor #455A64
skinparam noteBackgroundColor #FFFDE7
hide footbox

actor "Flutter UI\nObserver + Hooks" as UI
participant "Generated domain API\nset creation / direct entity actions\ndraft / typed list and lookup" as API
participant "EntityGraph\ntransaction coordinator" as Graph
participant "IdentityMap\nMobX projection" as Identity
database "Drift\nprojection + durable work" as DB
queue "Durable scheduler\nsync / process / projection lane" as Queue
participant "Generated router\n+ typed adapter" as Adapter
participant "Remote target\nSupabase / Convex / API" as Remote

== Typed read and observation ==
UI -> API : acquire typed <Entity>Query or <Entity>List
API -> Graph : structural query key + explicit lease
Graph -> DB : indexed/batched local query
DB --> Graph : typed rows
Graph -> Identity : materialize/update the same object per nominal ID
Identity --> UI : stable identities + exact fields/membership read
note over UI,Identity
  MobX records exactly what each Observer reads.
  Hooks own only widget-lifetime interaction resources.
end note

== Local-first mutation ==
UI -> API : create/fromSource / entity action / beginEdit().save() / transaction
API -> Graph : one typed mutation intent
Graph -> Graph : validate complete candidate + invariant + authorization
Graph -> Identity : one optimistic MobX action
Identity --> UI : immediate coherent projection

Graph -> DB : BEGIN local transaction
Graph -> DB : persist projection
opt replicated, exported, durable process, or secondary projection
  Graph -> DB : persist typed target/process/projection intent with stable operation ID
end
Graph -> DB : COMMIT
DB --> Graph : local durability confirmed
Graph --> API : Future completes
API --> UI : success means local commit, never remote completion

note over API,Graph
  transaction(FutureOr body) keeps one optimistic overlay and one atomic batch.
  Awaited inner mutations bind buffered commits; only the outer Future owns durability.
end note

alt local commit fails
  DB --> Graph : typed persistence failure
  Graph -> Identity : remove failed overlay; rebase later valid mutations
  Graph --> UI : typed failure after deterministic rollback/rebase
else local commit succeeds
  note over DB,Queue
    Projection and outbound work are atomic: neither can exist durably without the other.
  end note
end

== Asynchronous sync, process, or projection work ==
Queue -> DB : fairly claim bounded eligible work by target + direction
DB --> Queue : leased operation batch
Queue -> Adapter : generated typed payload + required version/receipt contract
Adapter -> Remote : idempotent target operation
Remote --> Adapter : canonical acknowledgement, process outcome, or projection receipt
Adapter -> DB : atomic base/outcome/receipt merge + pending-overlay rebase
DB -> Identity : publish only exact changed identities/fields/query membership
Identity --> UI : only dependent reactions rerun

== Collaboration and recovery ==
Remote -->> Adapter : realtime signal (wake-up hint only)
Adapter -> Queue : coalesce a durable pull request for this target
Queue -> Adapter : pull after independent monotonic target cursor
Adapter -> Remote : ordered change-log request
Remote --> Adapter : canonical snapshots/tombstones + next cursor
Adapter -> Adapter : validate descriptor/protocol; allowed deterministic upcast
Adapter -> DB : atomic base + projection + cursor update
DB -> Identity : update the same stable objects
Identity --> UI : exact observers and acquired lists react

note over Adapter,Remote
  Signals may be lost, delayed, or duplicated.
  Ordered cursor recovery is correctness; bounded snapshot recovery handles cursor expiry.
end note

note over UI,Remote
  No repository, provider mirror, feature refresh registry, direct remote write,
  raw patch map, duplicate DTO, per-row database stream, or global invalidation participates.
end note
@enduml


